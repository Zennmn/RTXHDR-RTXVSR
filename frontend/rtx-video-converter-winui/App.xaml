<Application
    x:Class="RTXVideoConverter.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:RTXVideoConverter.WinUI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Styles/DesignTokens.xaml" />
                <ResourceDictionary Source="Styles/ControlStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <FontFamily x:Key="ContentControlThemeFontFamily">Segoe UI</FontFamily>
            <x:Double x:Key="ControlContentThemeFontSize">16</x:Double>
            <x:Double x:Key="BodyTextBlockFontSize">14</x:Double>
            <x:Double x:Key="CaptionTextBlockFontSize">12</x:Double>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}" />
                <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
                <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
            </Style>

            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" Invert="True" />
            <converters:BackendStatusBrushConverter x:Key="BackendStatusBrushConverter" />
            <converters:JobStateTextConverter x:Key="JobStateTextConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
