<Page
    x:Class="RTXVideoConverter.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,16,24,16" Spacing="14" MaxWidth="820" HorizontalAlignment="Left">
            <StackPanel Spacing="6">
                <TextBlock Text="设置" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="调整外观，并查看系统辅助功能与动画状态。" Style="{StaticResource SecondaryTextStyle}" />
            </StackPanel>

            <Border Style="{StaticResource PanelStyle}" Translation="0,0,8">
                <StackPanel Spacing="4">
                    <TextBlock Text="个性化" Style="{StaticResource SectionTitleStyle}" Margin="4,4,4,12" />

                    <Grid MinHeight="72" Padding="4" ColumnDefinitions="Auto,*,240" ColumnSpacing="14">
                        <Border Style="{StaticResource IconTileStyle}" VerticalAlignment="Center">
                            <FontIcon
                                Glyph="&#xE790;"
                                FontSize="20"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="应用主题" FontWeight="SemiBold" />
                            <TextBlock Text="跟随 Windows，或固定使用浅色/深色。" Style="{StaticResource SecondaryTextStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ComboBox
                            Grid.Column="2"
                            SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="应用主题">
                            <ComboBoxItem Content="跟随系统" />
                            <ComboBoxItem Content="浅色" />
                            <ComboBoxItem Content="深色" />
                        </ComboBox>
                    </Grid>

                    <Rectangle Height="1" Fill="{ThemeResource SubtleStrokeBrush}" Margin="58,4,4,4" />

                    <Grid MinHeight="84" Padding="4" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Border Style="{StaticResource IconTileStyle}" VerticalAlignment="Center">
                            <FontIcon
                                Glyph="&#xE7F4;"
                                FontSize="20"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Fluent 动效" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind ViewModel.AnimationStatus, Mode=OneWay}" Style="{StaticResource SecondaryTextStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch
                            Grid.Column="2"
                            IsOn="{x:Bind ViewModel.SystemAnimationsEnabled, Mode=OneWay}"
                            IsEnabled="False"
                            OnContent="系统已开启"
                            OffContent="系统已减少"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Windows 系统动画状态" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelStyle}" Translation="0,0,8">
                <StackPanel Spacing="16">
                    <TextBlock Text="Windows 11 体验" Style="{StaticResource SectionTitleStyle}" />
                    <InfoBar
                        IsOpen="True"
                        IsClosable="False"
                        Severity="Informational"
                        Title="系统材质与辅助功能"
                        Message="窗口使用 Mica 作为底层材质；当系统关闭透明效果、进入节电模式或启用高对比度时，Windows 会自动切换为合适的纯色与系统颜色。" />
                    <TextBlock
                        Text="界面使用自然有效像素、原生文本缩放和键盘焦点顺序。更改 Windows 文本大小或对比度主题后，无需重新安装应用。"
                        Style="{StaticResource SecondaryTextStyle}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelStyle}" Translation="0,0,8">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Image Width="52" Height="52" Source="Assets/app-icon.png" Stretch="Uniform" />
                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="RTX Video Converter" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="版本 1.0.0" Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock Text="WinUI 3 · Windows App SDK · 原生 RTX 视频增强前端" Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock
                            Text="项目代码、FFmpeg（LGPL-2.1-or-later）和 NVIDIA RTX Video SDK 材料分别适用各自许可。"
                            Style="{StaticResource SecondaryTextStyle}"
                            TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="查看分发条款" Click="OpenDistributionTerms_Click" />
                            <HyperlinkButton
                                Content="FFmpeg 对应源码"
                                NavigateUri="https://github.com/Zennmn/RTXHDR-RTXVSR/releases/download/v1.0.0/RTX.Video.Converter_1.0.0_FFmpeg-corresponding-source.zip" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
