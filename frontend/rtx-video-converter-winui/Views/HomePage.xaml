<Page
    x:Class="RTXVideoConverter.WinUI.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:RTXVideoConverter.WinUI.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid x:Name="LayoutRoot" SizeChanged="LayoutRoot_SizeChanged">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowWidthStates">
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1180" />
                    </VisualState.StateTriggers>
                </VisualState>

                <VisualState x:Name="DenseWide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="900" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SidebarColumn.Width" Value="280" />
                        <Setter Target="BodyGapColumn.Width" Value="10" />
                        <Setter Target="ParameterColumnGap.Width" Value="10" />
                        <Setter Target="EncoderGapColumn1.Width" Value="10" />
                        <Setter Target="EncoderGapColumn2.Width" Value="10" />
                        <Setter Target="ModeSelectorBorder.Width" Value="480" />
                        <Setter Target="FooterHintColumn.Width" Value="0" />
                        <Setter Target="ActionHintText.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Medium">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="720" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SidebarColumn.Width" Value="320" />
                        <Setter Target="BodyGapColumn.Width" Value="12" />

                        <Setter Target="ParameterSecondColumn.Width" Value="0" />
                        <Setter Target="ParameterColumnGap.Width" Value="0" />
                        <Setter Target="ParameterRowGap.Height" Value="16" />
                        <Setter Target="ParameterSecondRow.Height" Value="Auto" />
                        <Setter Target="HdrCard.(Grid.Row)" Value="2" />
                        <Setter Target="HdrCard.(Grid.Column)" Value="0" />
                        <Setter Target="HdrCard.(Grid.ColumnSpan)" Value="3" />

                        <Setter Target="EncoderGapColumn1.Width" Value="0" />
                        <Setter Target="EncoderColumn1.Width" Value="0" />
                        <Setter Target="EncoderGapColumn2.Width" Value="0" />
                        <Setter Target="EncoderColumn2.Width" Value="0" />
                        <Setter Target="EncoderGapRow1.Height" Value="12" />
                        <Setter Target="EncoderRow1.Height" Value="Auto" />
                        <Setter Target="EncoderGapRow2.Height" Value="12" />
                        <Setter Target="EncoderRow2.Height" Value="Auto" />
                        <Setter Target="ContainerField.(Grid.Row)" Value="2" />
                        <Setter Target="ContainerField.(Grid.Column)" Value="0" />
                        <Setter Target="ContainerField.(Grid.ColumnSpan)" Value="5" />
                        <Setter Target="TracksField.(Grid.Row)" Value="4" />
                        <Setter Target="TracksField.(Grid.Column)" Value="0" />
                        <Setter Target="TracksField.(Grid.ColumnSpan)" Value="5" />

                        <Setter Target="FooterHintColumn.Width" Value="0" />
                        <Setter Target="ActionHintText.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Compact">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SidebarColumn.Width" Value="*" />
                        <Setter Target="BodyGapColumn.Width" Value="0" />
                        <Setter Target="WorkspaceColumn.Width" Value="0" />
                        <Setter Target="BodyRowGap.Height" Value="16" />
                        <Setter Target="WorkspaceStackRow.Height" Value="Auto" />
                        <Setter Target="SourcePanel.(Grid.ColumnSpan)" Value="3" />
                        <Setter Target="WorkspacePanel.(Grid.Row)" Value="2" />
                        <Setter Target="WorkspacePanel.(Grid.Column)" Value="0" />
                        <Setter Target="WorkspacePanel.(Grid.ColumnSpan)" Value="3" />
                        <Setter Target="SourcePanel.MinHeight" Value="0" />
                        <Setter Target="WorkspacePanel.MinHeight" Value="0" />

                        <Setter Target="ParameterSecondColumn.Width" Value="0" />
                        <Setter Target="ParameterColumnGap.Width" Value="0" />
                        <Setter Target="ParameterRowGap.Height" Value="16" />
                        <Setter Target="ParameterSecondRow.Height" Value="Auto" />
                        <Setter Target="HdrCard.(Grid.Row)" Value="2" />
                        <Setter Target="HdrCard.(Grid.Column)" Value="0" />
                        <Setter Target="HdrCard.(Grid.ColumnSpan)" Value="3" />

                        <Setter Target="EncoderGapColumn1.Width" Value="0" />
                        <Setter Target="EncoderColumn1.Width" Value="0" />
                        <Setter Target="EncoderGapColumn2.Width" Value="0" />
                        <Setter Target="EncoderColumn2.Width" Value="0" />
                        <Setter Target="EncoderGapRow1.Height" Value="12" />
                        <Setter Target="EncoderRow1.Height" Value="Auto" />
                        <Setter Target="EncoderGapRow2.Height" Value="12" />
                        <Setter Target="EncoderRow2.Height" Value="Auto" />
                        <Setter Target="ContainerField.(Grid.Row)" Value="2" />
                        <Setter Target="ContainerField.(Grid.Column)" Value="0" />
                        <Setter Target="ContainerField.(Grid.ColumnSpan)" Value="5" />
                        <Setter Target="TracksField.(Grid.Row)" Value="4" />
                        <Setter Target="TracksField.(Grid.Column)" Value="0" />
                        <Setter Target="TracksField.(Grid.ColumnSpan)" Value="5" />

                        <Setter Target="FooterActionColumn.Width" Value="0" />
                        <Setter Target="FooterHintColumn.Width" Value="0" />
                        <Setter Target="FooterActionGap.Height" Value="12" />
                        <Setter Target="FooterActionRow.Height" Value="Auto" />
                        <Setter Target="PrimaryActionButton.(Grid.Row)" Value="2" />
                        <Setter Target="PrimaryActionButton.(Grid.Column)" Value="0" />
                        <Setter Target="PrimaryActionButton.(Grid.ColumnSpan)" Value="4" />
                        <Setter Target="PrimaryActionButton.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="ActionHintText.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid RowDefinitions="*,Auto">
            <ScrollViewer
                x:Name="PageContentScrollViewer"
                Grid.Row="0"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Auto">
                <Grid x:Name="BodyGrid" Margin="12,16,20,16" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="SidebarColumn" Width="360" />
                        <ColumnDefinition x:Name="BodyGapColumn" Width="13" />
                        <ColumnDefinition x:Name="WorkspaceColumn" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="BodyRowGap" Height="0" />
                        <RowDefinition x:Name="WorkspaceStackRow" Height="0" />
                    </Grid.RowDefinitions>

                    <Border x:Name="SourcePanel" Grid.Column="0" MinHeight="800" Style="{StaticResource PanelStyle}" Padding="20,13,20,20" VerticalAlignment="Stretch" Translation="0,0,8">
                        <StackPanel x:Name="SourceContentStack" Spacing="16">
                            <TextBlock Text="输入源" Style="{StaticResource SidebarSectionTitleStyle}" />

                            <Border
                                x:Name="DropZone"
                                Margin="0,1,0,0"
                                MinHeight="187"
                                Background="{ThemeResource DropZoneBrush}"
                                CornerRadius="12"
                                AllowDrop="True"
                                DragOver="DropZone_DragOver"
                                Drop="DropZone_Drop"
                                behaviors:FluentMotion.IsHoverScaleEnabled="True">
                                <Grid>
                                    <Rectangle
                                        Margin="1"
                                        RadiusX="11"
                                        RadiusY="11"
                                        Stroke="{ThemeResource DropZoneStrokeBrush}"
                                        StrokeThickness="1"
                                        StrokeDashArray="5,4" />
                                    <Button
                                        Background="Transparent"
                                        BorderThickness="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Command="{x:Bind ViewModel.PickInputCommand}"
                                        AutomationProperties.Name="浏览并选择输入视频">
                                        <StackPanel x:Name="DropZoneContentStack" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                                            <Grid x:Name="DropZoneIconTile" Width="90" Height="90">
                                                <Ellipse Fill="{ThemeResource AccentSubtleBrush}" />
                                                <Image x:Name="DropZoneImage" Width="68" Height="68" Source="ms-appx:///Assets/drop-folder.png" Stretch="Uniform" />
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4" Translation="-1,-2,0">
                                                <TextBlock Text="拖拽视频至此或" FontSize="16.5" VerticalAlignment="Center" />
                                                <TextBlock Text="浏览" FontSize="16.5" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <TextBlock Text="支持常见视频格式" Style="{StaticResource SecondaryTextStyle}" FontSize="15" Translation="0,-3,0" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                            <StackPanel x:Name="InputPathStack" MaxWidth="320" Spacing="12" HorizontalAlignment="Stretch">
                                <TextBlock Text="输入路径" Style="{StaticResource SidebarFormLabelStyle}" />
                                <Border Style="{StaticResource PathFieldContainerStyle}">
                                    <Grid ColumnDefinitions="*,43">
                                        <TextBox
                                            Text="{x:Bind ViewModel.InputPath, Mode=OneWay}"
                                            Style="{StaticResource PathFieldTextBoxStyle}"
                                            PlaceholderText="拖拽视频或点击浏览选择文件"
                                            IsReadOnly="True"
                                            AutomationProperties.Name="输入视频路径" />
                                        <Button
                                            Grid.Column="1"
                                            Style="{StaticResource PathBrowseButtonStyle}"
                                            Command="{x:Bind ViewModel.PickInputCommand}"
                                            AutomationProperties.Name="选择输入视频"
                                            ToolTipService.ToolTip="选择输入视频">
                                            <FontIcon Glyph="&#xE8B7;" FontSize="16" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <Border x:Name="FileInfoCard" Margin="0,4,0,0" Style="{StaticResource InsetCardStyle}">
                                <StackPanel x:Name="FileInfoContentStack" Spacing="14">
                                    <TextBlock Text="文件信息" Style="{StaticResource SidebarFormLabelStyle}" />
                                    <Grid x:Name="FileInfoGrid" ColumnDefinitions="Auto,*" RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="文件名" Style="{StaticResource SidebarFieldLabelStyle}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.FileName, Mode=OneWay}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="220" />
                                        <TextBlock Grid.Row="1" Text="大小" Style="{StaticResource SidebarFieldLabelStyle}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.FileSize, Mode=OneWay}" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Row="2" Text="分辨率" Style="{StaticResource SidebarFieldLabelStyle}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.Resolution, Mode=OneWay}" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Row="3" Text="时长" Style="{StaticResource SidebarFieldLabelStyle}" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.Duration, Mode=OneWay}" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Row="4" Text="编码" Style="{StaticResource SidebarFieldLabelStyle}" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.SourceCodec, Mode=OneWay}" HorizontalAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="输出设置" Style="{StaticResource SidebarSectionTitleStyle}" />

                            <StackPanel x:Name="OutputDirectoryStack" MaxWidth="320" Spacing="12" HorizontalAlignment="Stretch">
                                <TextBlock Text="输出目录" Style="{StaticResource SidebarFormLabelStyle}" />
                                <Border Style="{StaticResource PathFieldContainerStyle}">
                                    <Grid ColumnDefinitions="*,43">
                                        <TextBox
                                            Text="{x:Bind ViewModel.OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Style="{StaticResource PathFieldTextBoxStyle}"
                                            IsEnabled="{x:Bind ViewModel.IsEditingEnabled, Mode=OneWay}"
                                            AutomationProperties.Name="输出目录" />
                                        <Button
                                            Grid.Column="1"
                                            Style="{StaticResource PathBrowseButtonStyle}"
                                            Command="{x:Bind ViewModel.PickOutputCommand}"
                                            AutomationProperties.Name="选择输出目录"
                                            ToolTipService.ToolTip="选择输出目录">
                                            <FontIcon Glyph="&#xE8B7;" FontSize="16" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel x:Name="OutputPreviewStack" MaxWidth="320" Spacing="12" HorizontalAlignment="Stretch">
                                <TextBlock Text="完整输出路径预览" Style="{StaticResource SidebarFormLabelStyle}" />
                                <Border
                                    Style="{StaticResource PathFieldContainerStyle}"
                                    Padding="12,0"
                                    AutomationProperties.Name="完整输出路径预览">
                                    <TextBlock
                                        Text="{x:Bind ViewModel.OutputPath, Mode=OneWay}"
                                        FontSize="15"
                                        VerticalAlignment="Center"
                                        TextTrimming="CharacterEllipsis" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="WorkspacePanel" Grid.Column="2" MinHeight="800" Style="{StaticResource PanelStyle}" Padding="16,20,16,16" VerticalAlignment="Stretch" Translation="0,0,4">
                        <StackPanel x:Name="WorkspaceContentStack" Spacing="20">
                            <StackPanel.ChildrenTransitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition FromVerticalOffset="12" IsStaggeringEnabled="True" />
                                </TransitionCollection>
                            </StackPanel.ChildrenTransitions>

                            <Border x:Name="BackendStatusCard" MinHeight="94" Style="{StaticResource CardStyle}" Translation="0,0,12">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="34" Translation="1,-3,0">
                                    <Image Width="52" Height="52" Source="ms-appx:///Assets/engine-status.png" Stretch="Uniform" />
                                    <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="后端状态" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.BackendMessage, Mode=OneWay}" Style="{StaticResource SecondaryTextStyle}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Border Grid.Column="2" Padding="14,8" CornerRadius="18" BorderBrush="{ThemeResource CardStrokeBrush}" BorderThickness="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Ellipse
                                                Width="9"
                                                Height="9"
                                                Fill="{x:Bind ViewModel.BackendStatus, Mode=OneWay, Converter={StaticResource BackendStatusBrushConverter}}"
                                                VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Bind ViewModel.CapabilitySummary, Mode=OneWay}" Style="{StaticResource SecondaryTextStyle}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border
                                x:Name="ModeSelectorBorder"
                                Width="520"
                                MaxWidth="540"
                                Margin="0,13,0,0"
                                Padding="4"
                                HorizontalAlignment="Left"
                                Background="{ThemeResource ModeBarSurfaceBrush}"
                                BorderBrush="{ThemeResource SubtleStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Translation="0,0,4">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <Grid x:Name="ModeButtonGrid" ColumnDefinitions="*,*,*" ColumnSpacing="4" SizeChanged="ModeButtonGrid_SizeChanged">
                                    <Border
                                        x:Name="ModeSelectionIndicator"
                                        Height="3"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="2"
                                        HorizontalAlignment="Left"
                                        IsHitTestVisible="False"
                                        VerticalAlignment="Bottom"
                                        Canvas.ZIndex="10">
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="ModeIndicatorTransform" />
                                        </Border.RenderTransform>
                                    </Border>
                                    <ToggleButton
                                        x:Name="VsrModeButton"
                                        Content="VSR 超分"
                                        Style="{StaticResource ModeToggleStyle}"
                                        IsChecked="{x:Bind ViewModel.IsVsrMode, Mode=OneWay}"
                                        IsEnabled="{x:Bind ViewModel.IsVsrAvailable, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.SelectVsrModeCommand}" />
                                    <ToggleButton
                                        x:Name="HdrModeButton"
                                        Grid.Column="1"
                                        Content="HDR 映射"
                                        Style="{StaticResource ModeToggleStyle}"
                                        IsChecked="{x:Bind ViewModel.IsHdrMode, Mode=OneWay}"
                                        IsEnabled="{x:Bind ViewModel.IsHdrAvailable, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.SelectHdrModeCommand}" />
                                    <ToggleButton
                                        x:Name="BothModeButton"
                                        Grid.Column="2"
                                        Content="VSR + HDR"
                                        Style="{StaticResource ModeToggleStyle}"
                                        IsChecked="{x:Bind ViewModel.IsBothMode, Mode=OneWay}"
                                        IsEnabled="{x:Bind ViewModel.IsBothModeAvailable, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.SelectBothModeCommand}" />
                                </Grid>
                            </Border>

                            <Grid x:Name="ParameterGrid" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.94*" />
                                    <ColumnDefinition x:Name="ParameterColumnGap" Width="16" />
                                    <ColumnDefinition x:Name="ParameterSecondColumn" Width="1.06*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition x:Name="ParameterRowGap" Height="0" />
                                    <RowDefinition x:Name="ParameterSecondRow" Height="0" />
                                </Grid.RowDefinitions>

                                <Border
                                    x:Name="VsrCard"
                                    Grid.Column="0"
                                    MinHeight="305"
                                    Style="{StaticResource CardStyle}"
                                    Translation="0,0,8"
                                    IsHitTestVisible="{x:Bind ViewModel.IsVsrConfigurationEnabled, Mode=OneWay}">
                                    <StackPanel x:Name="VsrContentStack" Spacing="24">
                                        <StackPanel Margin="4,0,0,0" Orientation="Horizontal" Spacing="12" Translation="0,-3,0">
                                            <Image Width="42" Height="42" Source="ms-appx:///Assets/vsr-parameter.png" Stretch="Uniform" />
                                            <TextBlock Text="VSR 参数" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="提升倍率" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ScaleFactorSummary, Mode=OneWay}" />
                                        </Grid>
                                        <Slider
                                            Minimum="1"
                                            Maximum="4"
                                            StepFrequency="0.1"
                                            Value="{x:Bind ViewModel.ScaleFactor, Mode=TwoWay}"
                                            AutomationProperties.Name="VSR 提升倍率">
                                            <Slider.Resources>
                                                <StaticResource x:Key="SliderTrackFill" ResourceKey="CustomSliderTrackBrush" />
                                                <StaticResource x:Key="SliderTrackFillPointerOver" ResourceKey="CustomSliderTrackBrush" />
                                                <x:Double x:Key="SliderHorizontalThumbWidth">22</x:Double>
                                                <x:Double x:Key="SliderHorizontalThumbHeight">22</x:Double>
                                                <x:Double x:Key="SliderInnerThumbWidth">14</x:Double>
                                                <x:Double x:Key="SliderInnerThumbHeight">14</x:Double>
                                                <CornerRadius x:Key="SliderThumbCornerRadius">11</CornerRadius>
                                            </Slider.Resources>
                                        </Slider>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="处理质量" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.QualityText, Mode=OneWay}" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,8,*,8,*,8,*">
                                            <ToggleButton Content="1" Style="{StaticResource QualityToggleStyle}" IsChecked="{x:Bind ViewModel.IsQuality1, Mode=OneWay}" Command="{x:Bind ViewModel.SelectQuality1Command}" />
                                            <ToggleButton Grid.Column="2" Content="2" Style="{StaticResource QualityToggleStyle}" IsChecked="{x:Bind ViewModel.IsQuality2, Mode=OneWay}" Command="{x:Bind ViewModel.SelectQuality2Command}" />
                                            <ToggleButton Grid.Column="4" Content="3" Style="{StaticResource QualityToggleStyle}" IsChecked="{x:Bind ViewModel.IsQuality3, Mode=OneWay}" Command="{x:Bind ViewModel.SelectQuality3Command}" />
                                            <ToggleButton Grid.Column="6" Content="4" Style="{StaticResource QualityToggleStyle}" IsChecked="{x:Bind ViewModel.IsQuality4, Mode=OneWay}" Command="{x:Bind ViewModel.SelectQuality4Command}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border
                                    x:Name="HdrCard"
                                    Grid.Column="2"
                                    MinHeight="305"
                                    Style="{StaticResource CardStyle}"
                                    IsHitTestVisible="{x:Bind ViewModel.IsHdrConfigurationEnabled, Mode=OneWay}">
                                    <StackPanel x:Name="HdrContentStack" Spacing="26">
                                        <StackPanel Margin="4,0,0,0" Orientation="Horizontal" Spacing="12" Translation="0,-3,0">
                                            <Image Width="42" Height="42" Source="ms-appx:///Assets/hdr-parameter.png" Stretch="Uniform" />
                                            <TextBlock Text="HDR 参数" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <Grid x:Name="HdrFieldsGrid" ColumnDefinitions="*,16,*" RowSpacing="30">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="对比度" Style="{StaticResource FieldLabelStyle}" />
                                                <ComboBox x:Name="ContrastComboBox" MinHeight="48" ItemsSource="{x:Bind ViewModel.ContrastOptions}" SelectedItem="{x:Bind ViewModel.Contrast, Mode=TwoWay}" HorizontalAlignment="Stretch" AutomationProperties.Name="HDR 对比度" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="8">
                                                <TextBlock Text="饱和度" Style="{StaticResource FieldLabelStyle}" />
                                                <ComboBox x:Name="SaturationComboBox" MinHeight="48" ItemsSource="{x:Bind ViewModel.SaturationOptions}" SelectedItem="{x:Bind ViewModel.Saturation, Mode=TwoWay}" HorizontalAlignment="Stretch" AutomationProperties.Name="HDR 饱和度" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Spacing="8">
                                                <TextBlock Text="中灰度" Style="{StaticResource FieldLabelStyle}" />
                                                <ComboBox x:Name="MiddleGrayComboBox" MinHeight="48" ItemsSource="{x:Bind ViewModel.MiddleGrayOptions}" SelectedItem="{x:Bind ViewModel.MiddleGray, Mode=TwoWay}" HorizontalAlignment="Stretch" AutomationProperties.Name="HDR 中灰度" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="2" Spacing="8">
                                                <TextBlock Text="最大亮度 (Nits)" Style="{StaticResource FieldLabelStyle}" />
                                                <ComboBox x:Name="LuminanceComboBox" MinHeight="48" ItemsSource="{x:Bind ViewModel.LuminanceOptions}" SelectedItem="{x:Bind ViewModel.MaxLuminance, Mode=TwoWay}" HorizontalAlignment="Stretch" AutomationProperties.Name="HDR 最大亮度" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border x:Name="EncoderCard" MinHeight="204" Margin="0,2,0,0" Style="{StaticResource CardStyle}" Translation="0,0,8" IsHitTestVisible="{x:Bind ViewModel.IsEditingEnabled, Mode=OneWay}">
                                <StackPanel x:Name="EncoderContentStack" Spacing="11">
                                    <StackPanel Margin="3,0,0,0" Orientation="Horizontal" Spacing="12" Translation="0,-7,0">
                                        <Image Width="42" Height="42" Source="ms-appx:///Assets/encoder-tracks.png" Stretch="Uniform" />
                                            <TextBlock Text="编码器与轨道" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <Grid Margin="2,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.066*" />
                                            <ColumnDefinition x:Name="EncoderGapColumn1" Width="16" />
                                            <ColumnDefinition x:Name="EncoderColumn1" Width="0.964*" />
                                            <ColumnDefinition x:Name="EncoderGapColumn2" Width="16" />
                                            <ColumnDefinition x:Name="EncoderColumn2" Width="1.07*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition x:Name="EncoderGapRow1" Height="0" />
                                            <RowDefinition x:Name="EncoderRow1" Height="0" />
                                            <RowDefinition x:Name="EncoderGapRow2" Height="0" />
                                            <RowDefinition x:Name="EncoderRow2" Height="0" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Spacing="12">
                                            <TextBlock Text="视频编码" Style="{StaticResource FieldLabelStyle}" />
                                            <ComboBox x:Name="CodecComboBox" MinHeight="48" SelectedIndex="{x:Bind ViewModel.SelectedCodecIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" AutomationProperties.Name="视频编码">
                                                <ComboBoxItem Content="NVENC H.264" IsEnabled="{x:Bind ViewModel.IsH264CodecOptionEnabled, Mode=OneWay}" />
                                                <ComboBoxItem Content="NVENC HEVC / H.265" IsEnabled="{x:Bind ViewModel.IsHevcCodecOptionEnabled, Mode=OneWay}" />
                                                <ComboBoxItem Content="NVENC AV1" IsEnabled="{x:Bind ViewModel.IsAv1CodecOptionEnabled, Mode=OneWay}" />
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel x:Name="ContainerField" Grid.Column="2" Spacing="12">
                                            <TextBlock Text="封装容器" Style="{StaticResource FieldLabelStyle}" />
                                            <ComboBox x:Name="ContainerComboBox" MinHeight="48" SelectedIndex="0" HorizontalAlignment="Stretch" AutomationProperties.Name="封装容器">
                                                <ComboBoxItem Content="MPEG-4 (.mp4)" />
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel x:Name="TracksField" Grid.Column="4" Spacing="12">
                                            <TextBlock Text="音频 / 字幕" Style="{StaticResource FieldLabelStyle}" />
                                            <StackPanel Orientation="Horizontal" Spacing="20">
                                                <CheckBox Content="音频" IsChecked="{x:Bind ViewModel.IncludeAudio, Mode=TwoWay}" />
                                                <CheckBox Content="字幕" IsChecked="{x:Bind ViewModel.IncludeSubtitles, Mode=TwoWay}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <InfoBar
                                Title="操作失败"
                                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                                IsOpen="{x:Bind ViewModel.HasError, Mode=TwoWay}"
                                IsClosable="True"
                                Severity="Error" />
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <Border x:Name="FooterPanel" Grid.Row="1" Margin="12,1,18,19" Style="{StaticResource PanelStyle}" Padding="20,11,16,11" Translation="0,0,12">
                <Grid x:Name="FooterGrid" ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="FooterActionColumn" Width="Auto" />
                        <ColumnDefinition x:Name="FooterHintColumn" Width="220" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="FooterActionGap" Height="0" />
                        <RowDefinition x:Name="FooterActionRow" Height="0" />
                    </Grid.RowDefinitions>

                    <Grid Width="64" Height="64" VerticalAlignment="Center">
                        <Ellipse Width="60" Height="60" Stroke="{ThemeResource CardStrokeBrush}" StrokeThickness="5" />
                        <ProgressRing
                            Width="64"
                            Height="64"
                            IsActive="{x:Bind ViewModel.HasActiveJob, Mode=OneWay}"
                            Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Grid.Column="1" Margin="2,0,0,0" Spacing="15" VerticalAlignment="Center" Translation="0,-5,0">
                        <TextBlock Text="{x:Bind ViewModel.JobStatusText, Mode=OneWay}" FontSize="15.5" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <Grid
                            x:Name="FooterProgressTrack"
                            Height="4"
                            AutomationProperties.Name="转码进度"
                            AutomationProperties.HelpText="{x:Bind ViewModel.ProgressText, Mode=OneWay}">
                            <Border Background="#FFD1D6DE" CornerRadius="2" />
                            <Border
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="2"
                                RenderTransformOrigin="0,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="FooterProgressTransform" ScaleX="0" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Button
                        x:Name="PrimaryActionButton"
                        Grid.Column="2"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Command="{x:Bind ViewModel.PrimaryCommand}"
                        IsEnabled="{x:Bind ViewModel.IsPrimaryActionEnabled, Mode=OneWay}"
                        AutomationProperties.Name="开始或取消视频转码">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#B80F6CBD" />
                            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#EFFFFFFF" />
                            <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                        </Button.Resources>
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2A6EF4" Offset="0" />
                                <GradientStop Color="#1761E7" Offset="1" />
                            </LinearGradientBrush>
                        </Button.Background>
                        <StackPanel Orientation="Horizontal" Spacing="9">
                            <FontIcon Glyph="&#xE768;" FontSize="16" Foreground="White" />
                            <TextBlock
                                Text="{x:Bind ViewModel.PrimaryActionText, Mode=OneWay}"
                                Foreground="White"
                                FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>

                    <TextBlock
                        x:Name="ActionHintText"
                        Grid.Column="3"
                        Text="{x:Bind ViewModel.ActionHint, Mode=OneWay}"
                        Style="{StaticResource SecondaryTextStyle}"
                        TextWrapping="Wrap"
                        VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
