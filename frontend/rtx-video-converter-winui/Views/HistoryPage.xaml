<Page
    x:Class="RTXVideoConverter.WinUI.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:RTXVideoConverter.Core.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="24" RowDefinitions="Auto,16,Auto,16,*">
        <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="6">
                <TextBlock Text="任务记录" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="转换结果会保存在本机，重新启动应用后仍可查看。" Style="{StaticResource SecondaryTextStyle}" />
            </StackPanel>
            <Button
                Grid.Column="1"
                Content="清空全部"
                Command="{x:Bind ViewModel.ClearCommand}"
                VerticalAlignment="Center"
                AutomationProperties.Name="清空全部任务记录" />
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,12,180">
            <TextBox
                PlaceholderText="搜索文件名或输出路径"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                AutomationProperties.Name="搜索任务记录" />
            <ComboBox
                Grid.Column="2"
                ItemsSource="{x:Bind ViewModel.FilterOptions}"
                SelectedItem="{x:Bind ViewModel.SelectedFilter, Mode=TwoWay}"
                DisplayMemberPath="Label"
                HorizontalAlignment="Stretch"
                AutomationProperties.Name="筛选任务状态" />
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource PanelStyle}" Translation="0,0,8" Padding="12">
            <Grid>
                <StackPanel
                    Visibility="{x:Bind ViewModel.HasNoItems, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    MaxWidth="420">
                    <Border Width="64" Height="64" CornerRadius="32" Background="{ThemeResource AccentSubtleBrush}" HorizontalAlignment="Center">
                        <FontIcon
                            Glyph="&#xE81C;"
                            FontSize="28"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{x:Bind ViewModel.EmptyTitle, Mode=OneWay}" Style="{StaticResource SectionTitleStyle}" HorizontalAlignment="Center" />
                    <TextBlock
                        Text="{x:Bind ViewModel.EmptyDescription, Mode=OneWay}"
                        Style="{StaticResource SecondaryTextStyle}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>

                <ListView
                    x:Name="HistoryList"
                    DataContext="{x:Bind ViewModel}"
                    ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.HasItems, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    SelectionMode="None"
                    IsItemClickEnabled="False">
                    <ListView.ItemContainerTransitions>
                        <TransitionCollection>
                            <AddDeleteThemeTransition />
                        </TransitionCollection>
                    </ListView.ItemContainerTransitions>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:JobHistoryItem">
                            <Border Margin="0,0,0,8" Padding="16,14" Style="{StaticResource InsetCardStyle}">
                                <Grid ColumnDefinitions="Auto,16,*,18,Auto" VerticalAlignment="Center">
                                    <Border Style="{StaticResource IconTileStyle}" VerticalAlignment="Center">
                                        <FontIcon
                                            Glyph="&#xE714;"
                                            FontSize="19"
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="2" Spacing="5" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{x:Bind OutputPath}" Style="{StaticResource SecondaryTextStyle}" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="14">
                                            <TextBlock Text="{x:Bind State, Converter={StaticResource JobStateTextConverter}}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind AverageFpsText}" Style="{StaticResource SecondaryTextStyle}" />
                                            <TextBlock Text="{x:Bind CompletedAtText}" Style="{StaticResource SecondaryTextStyle}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <Button
                                            Command="{Binding DataContext.OpenOutputCommand, ElementName=HistoryList}"
                                            CommandParameter="{x:Bind}"
                                            ToolTipService.ToolTip="打开输出文件"
                                            AutomationProperties.Name="打开输出文件">
                                            <FontIcon Glyph="&#xE8A7;" FontSize="15" />
                                        </Button>
                                        <Button
                                            Command="{Binding DataContext.OpenContainingFolderCommand, ElementName=HistoryList}"
                                            CommandParameter="{x:Bind}"
                                            ToolTipService.ToolTip="打开所在目录"
                                            AutomationProperties.Name="打开所在目录">
                                            <FontIcon Glyph="&#xE838;" FontSize="15" />
                                        </Button>
                                        <Button
                                            Command="{Binding DataContext.RemoveCommand, ElementName=HistoryList}"
                                            CommandParameter="{x:Bind}"
                                            ToolTipService.ToolTip="删除记录"
                                            AutomationProperties.Name="删除任务记录">
                                            <FontIcon Glyph="&#xE74D;" FontSize="15" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
