<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="PanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource PanelFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource PanelCornerRadiusToken}" />
        <Setter Property="Padding" Value="{StaticResource PanelPaddingToken}" />
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadiusToken}" />
        <Setter Property="Padding" Value="{StaticResource CardPaddingToken}" />
        <Setter Property="Shadow">
            <Setter.Value>
                <ThemeShadow />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InsetCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SubtleFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource SubtleStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadiusToken}" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppDisplayFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSection}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource TextHeadingBrush}" />
    </Style>

    <Style x:Key="SidebarSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSidebarSection}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource TextHeadingBrush}" />
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeFieldLabel}" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="Margin" Value="0,-1,0,1" />
    </Style>

    <Style x:Key="SidebarFormLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource TextHeadingBrush}" />
    </Style>

    <Style x:Key="SidebarFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="SecondaryTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSecondary}" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="IconTileStyle" TargetType="Border">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{ThemeResource AccentSubtleBrush}" />
    </Style>

    <Style x:Key="ModeToggleStyle" TargetType="ToggleButton">
        <Setter Property="MinHeight" Value="45" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMode}" />
        <Setter Property="Foreground" Value="{ThemeResource TextHeadingBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border
                            x:Name="SelectedSurface"
                            Background="{ThemeResource ModeSelectedSurfaceBrush}"
                            BorderBrush="{ThemeResource CardStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Opacity="0" />
                        <Border
                            x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Translation="0,-1,0"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <Border
                            x:Name="SelectionGloss"
                            Height="1"
                            Margin="7,1,7,0"
                            Background="{ThemeResource ModeGlossBrush}"
                            CornerRadius="1"
                            Opacity="0"
                            VerticalAlignment="Top" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualStateGroup.Transitions>
                                    <VisualTransition GeneratedDuration="0:0:0.2">
                                        <VisualTransition.GeneratedEasingFunction>
                                            <QuadraticEase EasingMode="EaseOut" />
                                        </VisualTransition.GeneratedEasingFunction>
                                    </VisualTransition>
                                </VisualStateGroup.Transitions>
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Target="SelectedSurface.Opacity" Value="0" />
                                        <Setter Target="SelectionGloss.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonSurface" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonSurface" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AccentSubtleHoverBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Opacity" To="0.45" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="SelectedSurface.Opacity" Value="1" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                        <Setter Target="SelectionGloss.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CheckedPointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="SelectedSurface.Opacity" Value="1" />
                                        <Setter Target="ButtonSurface.Background" Value="{ThemeResource AccentSubtleHoverBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                        <Setter Target="SelectionGloss.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CheckedPressed">
                                    <VisualState.Setters>
                                        <Setter Target="SelectedSurface.Opacity" Value="1" />
                                        <Setter Target="ButtonSurface.Background" Value="{ThemeResource AccentSubtleHoverBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                        <Setter Target="SelectionGloss.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CheckedDisabled">
                                    <VisualState.Setters>
                                        <Setter Target="SelectedSurface.Opacity" Value="0.45" />
                                        <Setter Target="ContentPresenter.Opacity" Value="0.45" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                        <Setter Target="SelectionGloss.Opacity" Value="0.45" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Indeterminate" />
                                <VisualState x:Name="IndeterminatePointerOver" />
                                <VisualState x:Name="IndeterminatePressed" />
                                <VisualState x:Name="IndeterminateDisabled" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="QualityToggleStyle" TargetType="ToggleButton">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeQuality}" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style x:Key="PathFieldContainerStyle" TargetType="Border">
        <Setter Property="Height" Value="40" />
        <Setter Property="Background" Value="{ThemeResource CardFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style x:Key="PathFieldTextBoxStyle" TargetType="TextBox">
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style x:Key="PathBrowseButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="43" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1,0,0,0" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
        <Setter Property="MinWidth" Value="168" />
        <Setter Property="MinHeight" Value="52" />
        <Setter Property="Padding" Value="24,12" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodyLarge}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="FooterProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="4" />
        <Setter Property="MinHeight" Value="4" />
        <Setter Property="Foreground" Value="{ThemeResource AccentFillColorDefaultBrush}" />
        <Setter Property="Background" Value="#FFD1D6DE" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid x:Name="LayoutRoot" Height="4" Background="Transparent">
                        <Border
                            Height="4"
                            Background="{TemplateBinding Background}"
                            CornerRadius="2" />
                        <Border
                            x:Name="DeterminateProgressBarIndicator"
                            Height="4"
                            HorizontalAlignment="Left"
                            Background="{TemplateBinding Foreground}"
                            CornerRadius="2" />
                        <Border
                            x:Name="IndeterminateProgressBarIndicator"
                            Width="96"
                            Height="4"
                            HorizontalAlignment="Left"
                            Background="{TemplateBinding Foreground}"
                            CornerRadius="2"
                            Visibility="Collapsed" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Determinate" />
                                <VisualState x:Name="Indeterminate">
                                    <VisualState.Setters>
                                        <Setter Target="DeterminateProgressBarIndicator.Visibility" Value="Collapsed" />
                                        <Setter Target="IndeterminateProgressBarIndicator.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
