<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#FFF3F4FA" />
            <SolidColorBrush x:Key="AppLayerBrush" Color="#FFF4F7FB" />
            <SolidColorBrush x:Key="NavigationLayerBrush" Color="#FFEEF1F6" />
            <SolidColorBrush x:Key="PanelFillBrush" Color="#8CFFFFFF" />
            <SolidColorBrush x:Key="CardFillBrush" Color="#88FFFFFF" />
            <SolidColorBrush x:Key="SubtleFillBrush" Color="#FFF8FAFD" />
            <SolidColorBrush x:Key="CardStrokeBrush" Color="#160F2847" />
            <SolidColorBrush x:Key="SubtleStrokeBrush" Color="#100F2847" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F0000000" />
            <SolidColorBrush x:Key="TextHeadingBrush" Color="#F8000000" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B30F2038" />
            <SolidColorBrush x:Key="AccentSubtleBrush" Color="#E8F1FF" />
            <SolidColorBrush x:Key="AccentSubtleHoverBrush" Color="#DDEAFF" />
            <SolidColorBrush x:Key="StatusSuccessBrush" Color="#149447" />
            <SolidColorBrush x:Key="StatusWarningBrush" Color="#C47A05" />
            <SolidColorBrush x:Key="StatusErrorBrush" Color="#C42B1C" />
            <SolidColorBrush x:Key="StatusNeutralBrush" Color="#6B7280" />
            <SolidColorBrush x:Key="DropZoneBrush" Color="#38FFFFFF" />
            <SolidColorBrush x:Key="DropZoneStrokeBrush" Color="#663C7FE8" />
            <SolidColorBrush x:Key="CustomSliderTrackBrush" Color="#FFD2D6DD" />
            <LinearGradientBrush x:Key="ModeBarSurfaceBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FCFFFFFF" Offset="0" />
                <GradientStop Color="#FFF5F8FC" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="ModeSelectedSurfaceBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFFFFFFF" Offset="0" />
                <GradientStop Color="#FFF7FAFF" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="ModeGlossBrush" Color="#DFFFFFFF" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#CC202124" />
            <SolidColorBrush x:Key="AppLayerBrush" Color="#40121418" />
            <SolidColorBrush x:Key="NavigationLayerBrush" Color="#30121418" />
            <SolidColorBrush x:Key="PanelFillBrush" Color="#C923252A" />
            <SolidColorBrush x:Key="CardFillBrush" Color="#E02B2D32" />
            <SolidColorBrush x:Key="SubtleFillBrush" Color="#6032363D" />
            <SolidColorBrush x:Key="CardStrokeBrush" Color="#26FFFFFF" />
            <SolidColorBrush x:Key="SubtleStrokeBrush" Color="#18FFFFFF" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F2FFFFFF" />
            <SolidColorBrush x:Key="TextHeadingBrush" Color="#FAFFFFFF" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B8FFFFFF" />
            <SolidColorBrush x:Key="AccentSubtleBrush" Color="#303C7FE8" />
            <SolidColorBrush x:Key="AccentSubtleHoverBrush" Color="#454886E8" />
            <SolidColorBrush x:Key="StatusSuccessBrush" Color="#54C77A" />
            <SolidColorBrush x:Key="StatusWarningBrush" Color="#F3B95F" />
            <SolidColorBrush x:Key="StatusErrorBrush" Color="#FF99A4" />
            <SolidColorBrush x:Key="StatusNeutralBrush" Color="#AEB6C2" />
            <SolidColorBrush x:Key="DropZoneBrush" Color="#263B414A" />
            <SolidColorBrush x:Key="DropZoneStrokeBrush" Color="#995E9BFF" />
            <SolidColorBrush x:Key="CustomSliderTrackBrush" Color="#FF666B73" />
            <LinearGradientBrush x:Key="ModeBarSurfaceBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#D83A3D43" Offset="0" />
                <GradientStop Color="#D82B2E34" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="ModeSelectedSurfaceBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F044474E" Offset="0" />
                <GradientStop Color="#F0363940" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="ModeGlossBrush" Color="#30FFFFFF" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="AppLayerBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="NavigationLayerBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PanelFillBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="CardFillBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="SubtleFillBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="CardStrokeBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="SubtleStrokeBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="TextHeadingBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AccentSubtleBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="AccentSubtleHoverBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="StatusSuccessBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="StatusWarningBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="StatusErrorBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="StatusNeutralBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="DropZoneBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="DropZoneStrokeBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="CustomSliderTrackBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="ModeBarSurfaceBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="ModeSelectedSurfaceBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="ModeGlossBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <FontFamily x:Key="AppTextFontFamily">Segoe UI</FontFamily>
    <FontFamily x:Key="AppDisplayFontFamily">Segoe UI</FontFamily>
    <x:Double x:Key="FontSizeCaption">12</x:Double>
    <x:Double x:Key="FontSizeBody">14</x:Double>
    <x:Double x:Key="FontSizeSecondary">14</x:Double>
    <x:Double x:Key="FontSizeFieldLabel">15</x:Double>
    <x:Double x:Key="FontSizeBodyLarge">16.5</x:Double>
    <x:Double x:Key="FontSizeMode">16.5</x:Double>
    <x:Double x:Key="FontSizeQuality">17</x:Double>
    <x:Double x:Key="FontSizeSection">18.5</x:Double>
    <x:Double x:Key="FontSizeSidebarSection">19.5</x:Double>
    <x:Double x:Key="FontSizeTitle">24</x:Double>

    <CornerRadius x:Key="ControlCornerRadiusToken">8</CornerRadius>
    <CornerRadius x:Key="CardCornerRadiusToken">12</CornerRadius>
    <CornerRadius x:Key="PanelCornerRadiusToken">16</CornerRadius>
    <Thickness x:Key="CardPaddingToken">20</Thickness>
    <Thickness x:Key="PanelPaddingToken">16</Thickness>

    <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="#F2F6FF" />
    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#DDEAFF" />
    <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="#0F5CD8" />
    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="#0B52C4" />
    <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="#1D5FE9" />
    <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPointerOver" Color="#174DB9" />
</ResourceDictionary>
